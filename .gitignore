# --- PocketHash Project Specifics ---

# Solana / Wallet Security (EXTREM WICHTIG)
# Verhindert, dass deine Private Keys oder Paper Wallets auf GitHub landen
*.json
!package.json
!tsconfig.json

# Environment / API Keys
# Schützt deine Helius API Keys und Poof Cloud Credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dependency Manager
# Schließt den riesigen Ordner mit den Bibliotheken aus
node_modules/

# Build Output (Vite / React)
# Ignoriert den fertigen Code, der für das Web-Deployment erzeugt wird
dist/
build/
*.pyc

# IDE / Editor
# Ignoriert Konfigurationen von Editoren (falls du doch Cursor/VS Code nutzt)
.vscode/
.idea/
.DS_Store
thumbs.db

# Poof Policy / Temporary
# Falls das Poof CLI oder dein Deployment-Prozess temporäre Logs erzeugt
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
